KP_USER_ID=12345678

KINOPOISK_DEV_TOKEN=

OMDB_API_KEY=

HEADLESS=false

SCRAPE_DELAY_SEC=1.5

# Прокси для обхода блокировки. Поддерживается http/https/socks5.
# Примеры:
#   PROXY_URL=socks5://127.0.0.1:1080            (SSH-туннель через VPS: ssh -D 1080 user@vps)
#   PROXY_URL=http://user:pass@proxy.host:8080   (residential proxy с авторизацией)
# Оставь пустым, если сайт открывается напрямую.
PROXY_URL=

# Если твой профиль на Кинопоиске публичный — можно парсить без логина.
# Тогда достаточно только прокси, интерактивный вход пропускается.
KP_PUBLIC_MODE=false
